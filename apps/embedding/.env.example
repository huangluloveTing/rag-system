# ================================
# Embedding Service 配置
# ================================
PORT=8001
HOST=0.0.0.0

# 模式选择：true 使用本地模型，false 使用外部 API
USE_LOCAL_MODELS=false

# 预加载模型（可选）
PRELOAD_MODELS=false

# ================================
# 外部 API 配置（USE_LOCAL_MODELS=false 时使用）
# ================================
# Embedding API 配置
EMBEDDING_API_URL=http://ip./v1/embeddings
EMBEDDING_API_KEY=sk-****
EMBEDDING_MODEL=qwen/qwen3-embedding-4b

# Rerank API 配置（Ollama）
RERANK_API_URL=http://localhost:11434/api
RERANK_MODEL=dengcao/Qwen3-Reranker-0.6B:Q8_0
RERANK_API_KEY=